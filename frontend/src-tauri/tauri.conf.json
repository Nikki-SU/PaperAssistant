{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PaperAssistant",
  "version": "0.1.0",
  "identifier": "com.rosa.paperassistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PaperAssistant",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright © 2026 Rosa",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": ["binaries/paperassistant-backend"],
    "resources": ["resources/tectonic/*"],
    "windows": {
      "wix": {
        "language": ["en-US", "zh-CN"]
      },
      "nsis": {
        "languages": ["English", "SimpChinese"]
      }
    }
  }
}
