{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PaperAssistant",
  "version": "0.1.0",
  "identifier": "com.nikki-su.paperassistant",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PaperAssistant",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": [
      "binaries/paperassistant-backend"
    ]
  }
}
